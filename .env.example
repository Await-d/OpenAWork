# Environment: dev | staging | prod
NODE_ENV=dev

# ─── Agent Gateway ───────────────────────────────────────────────────────────
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0

# JWT signing secret (min 32 chars). Generate: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Gateway Storage (SQLite + backups + artifacts) ─────────────────────────
# Preferred: durable data root for the gateway. When unset, defaults to the
# platform data dir (Linux: ~/.local/share/OpenAWork/agent-gateway).
OPENAWORK_DATA_DIR=

# Optional explicit SQLite file path. Overrides OPENAWORK_DATA_DIR for DB only.
OPENAWORK_DATABASE_PATH=

# Legacy SQLite path override kept for compatibility. Do NOT set a Postgres URL.
DATABASE_URL=

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AI Model ────────────────────────────────────────────────────────────────
# Never commit real API keys. Inject via CI secrets or secret manager.
AI_API_KEY=
AI_API_BASE_URL=https://api.openai.com/v1
AI_DEFAULT_MODEL=gpt-4o

# ─── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info
