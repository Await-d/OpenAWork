{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "paths": {
      "@openAwork/agent-core": ["../agent-core/src/index.ts"],
      "@openAwork/shared": ["../shared/src/index.ts"]
    }
  },
  "references": [{ "path": "../agent-core" }, { "path": "../shared" }],
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
