{
  "expo": {
    "name": "OpenAWork",
    "slug": "openAwork",
    "scheme": "openawork",
    "version": "0.2.0",
    "orientation": "portrait",
    "platforms": ["ios", "android"],
    "updates": {
      "url": "https://u.expo.dev/5d5fee00-cf47-4452-a6b3-238c1b84eb0c",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 3000
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "ios": {
      "bundleIdentifier": "com.openAwork.mobile",
      "supportsTablet": true
    },
    "android": {
      "package": "com.openAwork.mobile",
      "adaptiveIcon": { "backgroundColor": "#ffffff" }
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "允许 OpenAWork 使用麦克风进行语音输入。",
          "speechRecognitionPermission": "允许 OpenAWork 使用语音识别将语音转换为文本。",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ]
    ],
    "extra": {
      "eas": { "projectId": "5d5fee00-cf47-4452-a6b3-238c1b84eb0c" }
    }
  }
}
