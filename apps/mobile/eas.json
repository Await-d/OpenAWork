{
  "cli": {
    "version": ">= 12.0.0",
    "requireCommit": true
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_GATEWAY_URL": "http://localhost:3000"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "enterpriseProvisioning": "adhoc"
      },
      "env": {
        "EXPO_PUBLIC_GATEWAY_URL": "https://gateway-staging.openwork.app"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_GATEWAY_URL": "https://gateway.openwork.app"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "$(APPLE_ID)",
        "ascAppId": "$(ASC_APP_ID)",
        "appleTeamId": "$(APPLE_TEAM_ID)"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
