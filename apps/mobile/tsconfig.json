{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-native",
    "baseUrl": ".",
    "outDir": "./dist",
    "skipLibCheck": true,
    "paths": {
      "@openAwork/artifacts": ["../../packages/artifacts/src/index.ts"],
      "@openAwork/shared": ["../../packages/shared/src/index.ts"],
      "@openAwork/agent-core": ["../../packages/agent-core/src/index.ts"],
      "@openAwork/web-client": ["../../packages/web-client/src/index.ts"]
    }
  },
  "include": ["src", "app", "app.config.ts"],
  "exclude": [
    "node_modules",
    "../../packages/agent-core/src/worker",
    "../../packages/agent-core/src/orchestrator-cli",
    "../../packages/agent-core/src/ssh"
  ]
}
