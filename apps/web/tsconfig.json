{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@openAwork/artifacts": ["../../packages/artifacts/src/index.ts"],
      "@openAwork/logger": ["../../packages/logger/src/index.ts"],
      "@openAwork/shared": ["../../packages/shared/src/index.ts"],
      "@openAwork/shared-ui": ["../../packages/shared-ui/src/index.ts"],
      "@openAwork/web-client": ["../../packages/web-client/src/index.ts"]
    },
    "outDir": "./dist",
    "composite": false,
    "noEmit": true
  },
  "include": ["src", "../../packages/shared/src/version.d.ts"],
  "exclude": ["node_modules", "dist"]
}
