{
  "name": "@openAwork/web",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "preview:ci": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:chat:regression": "vitest run src/hooks/useGatewayClient.test.tsx src/components/Layout.questions.test.tsx src/components/Layout.permissions.test.tsx src/components/Layout.test.tsx src/pages/ChatPage.test.tsx",
    "test:e2e:attach-recovery": "playwright test e2e/chat-stream-attach-recovery.spec.ts --project=chromium",
    "test:chat:fast": "pnpm run test:chat:regression && pnpm run test:e2e:attach-recovery",
    "test:e2e": "playwright test -c playwright.ci.config.ts",
    "test:e2e:attach-live": "playwright test -c playwright.attach-live.config.mjs e2e/chat-stream-attach-live.spec.ts --project=chromium",
    "lint": "node -e \"console.log('跳过 apps/web lint：当前阶段仅收口 desktop/mobile')\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@openAwork/artifacts": "workspace:*",
    "@openAwork/logger": "workspace:*",
    "@openAwork/shared": "workspace:*",
    "@openAwork/shared-ui": "workspace:*",
    "@openAwork/web-client": "workspace:*",
    "@types/three": "^0.183.1",
    "fuzzysort": "^3.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.0.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "three": "^0.183.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.0"
  }
}
