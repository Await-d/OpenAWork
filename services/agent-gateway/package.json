{
  "name": "@openAwork/agent-gateway",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:binary": "bun build src/index.ts --compile --outfile dist/agent-gateway",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run test:unit && pnpm run test:verification",
    "test:unit": "vitest run --passWithNoTests",
    "test:verification": "pnpm run test:responses && pnpm run test:permissions && pnpm run test:session-tasks && pnpm run test:task-tool && pnpm run test:claude-tools",
    "test:responses": "tsx src/verification/verify-openai-responses.ts",
    "test:permissions": "tsx src/verification/verify-permissions-routes.ts",
    "test:session-tasks": "tsx src/verification/verify-session-task-routes.ts && tsx src/verification/verify-session-delete-child-detach.ts",
    "test:task-tool": "tsx src/verification/verify-task-tool-no-permission.ts && tsx src/verification/verify-task-tool-auto-run.ts && tsx src/verification/verify-task-tool-failure-propagation.ts && tsx src/verification/verify-task-tool-pending-interaction-resume.ts && tsx src/verification/verify-task-tool-question-resume.ts",
    "test:claude-tools": "tsx src/verification/verify-claude-first-tools.ts",
    "lint": "eslint .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "@octokit/rest": "^22.0.1",
    "@openAwork/agent-core": "workspace:*",
    "@openAwork/artifacts": "workspace:*",
    "@openAwork/browser-automation": "workspace:*",
    "@openAwork/logger": "workspace:*",
    "@openAwork/lsp-client": "workspace:*",
    "@openAwork/mcp-client": "workspace:*",
    "@openAwork/pairing": "workspace:*",
    "@openAwork/shared": "workspace:*",
    "@openAwork/skill-registry": "workspace:*",
    "@openAwork/skills": "workspace:*",
    "@slack/bolt": "^4.4.0",
    "@types/turndown": "^5.0.6",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.1.0",
    "pdf-parse": "^2.4.5",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "turndown": "^7.2.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.0.0",
    "vitest": "^2.1.9"
  }
}
